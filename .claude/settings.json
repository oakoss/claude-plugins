{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/version-bump-gate.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [],
    "ask": [],
    "defaultMode": "plan",
    "deny": []
  },
  "plansDirectory": ".claude/plans",
  "sandbox": {
    "autoAllowBashIfSandboxed": false,
    "enabled": false
  },
  "spinnerTipsEnabled": false
}
