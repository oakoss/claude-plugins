#!/usr/bin/env bash
# review-sentinel: state for the review-cycle gate.
#
# Subcommands:
#   seed         Write current state. Always overwrites. Used by SessionStart.
#   mark         Write current state. Always overwrites. Used by /accept
#                and /review Phase 8.
#   check        Exit 0 if clean tree OR sentinel matches; 1 if drifted; 2 on
#                error (no git repo, no sha tool). Hooks should fail-open on 2.
#   match        Exit 0 only if sentinel exists AND its hash equals current
#                hash computed from its anchor. No clean-tree fast-path.
#                Used by session-init to decide on idempotent re-seed.
#   current-hash Print current hash computed from current HEAD (or the
#                empty tree for unborn HEAD) to stdout.
#   paths        Print sentinel and opt-out paths (relative to project root,
#                one per line) for use in .gitignore.
#
# Format on disk: two lines.
#   anchor:<40-hex-sha>     ← HEAD SHA at mark time, or the empty-tree SHA
#                             (4b825dc6…) when HEAD is unborn
#   sha256:<64-hex-chars>   ← hash of the anchor→index and index→working-tree
#                             diffs (untracked files normalized via a scratch
#                             intent-to-add index; see compute_hash_from_anchor)
# Path: <project-root>/.claude/.review-mark
#
# Why anchor + diff-hash instead of one hash: each `git commit` advances HEAD
# and shrinks `git diff HEAD`, so a HEAD-relative sentinel drifts the moment
# any reviewed work is committed. Anchoring at the commit that was HEAD at
# mark time means subsequent commits of already-reviewed content leave the
# anchor→working-tree diff unchanged, so a single review covers an arbitrary
# number of follow-up commits.
#
# Project root resolution (in order):
#   1. --root <path> flag (explicit)
#   2. CLAUDE_PROJECT_DIR env var (set by Claude Code)
#   3. git rev-parse --show-toplevel from current cwd

set -uo pipefail

EMPTY_TREE_SHA="4b825dc642cb6eb9a060e54bf8d69288fbee4904"

usage() {
  cat >&2 <<EOF
usage: review-sentinel [--root <path>] <subcommand>

subcommands:
  seed          write current state (used by SessionStart)
  mark          write current state (used by /accept and /review)
  check         exit 0=clean/match, 1=drift, 2=error
  match         exit 0=exact match only (no clean-tree shortcut)
  current-hash  print current state
  paths         print gitignore-relative paths
EOF
  exit 2
}

pick_sha() {
  if command -v sha256sum >/dev/null 2>&1; then
    echo "sha256sum"
  elif command -v shasum >/dev/null 2>&1; then
    echo "shasum -a 256"
  else
    return 1
  fi
}

# Path to the per-project config file. Intentionally NOT included in the
# default excludes; see SECURITY note below.
CONFIG_PATH=".claude/review-cycle.json"

# Declared here so `set -u` doesn't error before the first build_excludes call.
EXCLUDES_LIST=()

# SECURITY: the config file itself is intentionally NOT in the default
# excludes. compute_hash_from_anchor and is_clean_tree force-include
# CONFIG_PATH in their inputs, so user `ignore` patterns matching the config
# (`**`, `.claude/**`, etc.) cannot hide config edits from the hash. Editing
# the config always forces a review pass before its rules take effect.
build_excludes() {
  local root="$1" pattern
  # Excluded at any depth: a monorepo subpackage's `.beads/` would otherwise
  # read as code drift and gate the commit. The bare-root form is kept because
  # older git pathspec parsers treat a leading `**/` as one-or-more dirs, not
  # zero-or-more.
  EXCLUDES_LIST=(
    ':(exclude).claude/.review-mark'
    ':(exclude).claude/.no-review-gate'
    ':(exclude,glob).beads/**'
    ':(exclude,glob)**/.beads/**'
    ':(exclude,glob).trekker/**'
    ':(exclude,glob)**/.trekker/**'
    ':(exclude,glob).vscode/**'
    ':(exclude,glob)**/.vscode/**'
    ':(exclude,glob).idea/**'
    ':(exclude,glob)**/.idea/**'
    ':(exclude,glob).zed/**'
    ':(exclude,glob)**/.zed/**'
    ':(exclude,glob).cursor/**'
    ':(exclude,glob)**/.cursor/**'
    ':(exclude,glob).fleet/**'
    ':(exclude,glob)**/.fleet/**'
  )
  local config_file="$root/$CONFIG_PATH"
  [ -f "$config_file" ] || return 0
  command -v jq >/dev/null 2>&1 || return 0
  while IFS= read -r pattern; do
    [ -z "$pattern" ] && continue
    EXCLUDES_LIST+=(":(exclude,glob)$pattern")
  done < <(jq -r '(.ignore // []) | .[]? | select(type == "string")' "$config_file" 2>/dev/null)
}

resolve_project_root() {
  local candidate
  for candidate in "$ROOT_OVERRIDE" "${CLAUDE_PROJECT_DIR:-}"; do
    [ -n "$candidate" ] || continue
    [ -d "$candidate" ] || continue
    git -C "$candidate" rev-parse --show-toplevel 2>/dev/null && return 0
  done
  git rev-parse --show-toplevel 2>/dev/null
}

# Resolve current anchor: HEAD SHA if present, empty-tree SHA otherwise.
current_anchor() {
  local root="$1" sha
  sha=$(git -C "$root" rev-parse HEAD 2>/dev/null) && {
    echo "$sha"
    return 0
  }
  echo "$EMPTY_TREE_SHA"
}

# Populate the throwaway index at $2 from $1's real index, then intent-to-add
# the untracked files so the index→working-tree diff renders each as a
# new-file patch byte-identical to its staged form (which is what lets an
# untracked, staged, and committed new file all hash the same). Uses the
# global EXCLUDES_LIST and CONFIG_PATH. Returns nonzero if any cp/git step
# fails; the caller must treat that as drift, never a clean hash. $2 must not
# already exist as a non-empty file — git rejects a 0-byte index as corrupt.
# Runs `cd "$root"`, so callers invoke it in a subshell to contain that.
build_scratch_index() {
  local root="$1" scratch="$2" realidx
  cd "$root" || return 1
  realidx=$(git rev-parse --git-path index)
  if [ -f "$realidx" ]; then cp "$realidx" "$scratch" || return 1; fi
  # Only intent-add when there are untracked files: GNU xargs (unlike BSD)
  # runs the command once even on empty input, so an unguarded pipe would
  # invoke `git add -N --` with no paths and fail on a clean or tracked-only
  # tree. The guard skips xargs entirely in that common case. `xargs -0`
  # propagates a `git add` failure (e.g. a path that vanished mid-run).
  if [ -n "$(git ls-files --others --exclude-standard -- "${EXCLUDES_LIST[@]}")" ]; then
    git ls-files --others --exclude-standard -z -- "${EXCLUDES_LIST[@]}" \
      | GIT_INDEX_FILE="$scratch" xargs -0 git add -N -- 2>/dev/null || return 1
  fi
  # Force-include the config even when gitignored (common when the project
  # gitignores all of .claude/), so its untracked bytes always reach the hash.
  # -f overrides the ignore; -N keeps it an intent-to-add like the others so
  # staged and untracked config hash the same way.
  if [ -f "$CONFIG_PATH" ] \
     && ! git ls-files --error-unmatch -- "$CONFIG_PATH" >/dev/null 2>&1; then
    GIT_INDEX_FILE="$scratch" git add -Nf -- "$CONFIG_PATH" 2>/dev/null || return 1
  fi
}

# Compute the sha256 of the diff from anchor to the current effective state
# (anchor→index AND index→working-tree, per path, sorted by path). Returns 0
# with hash on stdout; 1 on unrecoverable error (no work tree, no sha tool,
# pipeline failure); 2 if the anchor is not reachable as a commit or tree in
# the object database.
#
# Per-path iteration with sorted ordering is what makes the hash invariant
# under four different transformations of the same content:
#
#   1. Committing reviewed content. After commit, --cached <anchor> covers
#      the committed delta and `git diff` covers what remains uncommitted.
#      The combined per-path bytes match the pre-commit state where the same
#      content was all in `git diff`.
#   2. Staging or unstaging reviewed content (no content change). With
#      --no-prefix the cached and uncached diff streams produce byte-identical
#      output for the same content delta, so moving content between staged
#      and unstaged does not drift the hash.
#   3. Staging a reviewed *new* file. An untracked file would otherwise hash
#      via a different representation than its staged form, so `git add`-ing
#      it between mark and commit read as drift. To normalize, untracked files
#      are intent-to-added (`git add -N`) into a throwaway copy of the index
#      and the index→working-tree segment is diffed against that scratch
#      index. Intent-to-add makes `git diff` emit a new file exactly as
#      `git diff --cached` emits a staged add, so untracked, staged, and
#      committed forms of the same new file all hash identically. The real
#      index and working tree are never mutated.
#   4. Codex P1 bypass — staging unreviewed content and then restoring the
#      working tree to the reviewed state. The --cached diff (against the real
#      index) captures the unreviewed index content, so the hash changes and
#      the gate fires. The scratch index covers only the worktree segment, so
#      it cannot mask an index/worktree divergence.
#
# A naïve `--cached anchor` ++ `diff` concatenation breaks property 1: the
# alphabetical ordering shifts across stream boundaries (e.g. {bar, foo}
# alphabetical in one stream pre-commit, then {foo cached, bar unstaged}
# split across two streams post-commit). Sorting paths and emitting both
# streams per path keeps the output order stable regardless of which stream
# a particular file's diff lives in.
compute_hash_from_anchor() {
  local root="$1" anchor="$2" sha h kind paths scratch rc=0
  git -C "$root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
    echo "review-sentinel: not inside a git work tree" >&2
    return 1
  }
  sha=$(pick_sha) || {
    echo "review-sentinel: no sha256 tool (sha256sum/shasum missing?)" >&2
    return 1
  }
  kind=$(git -C "$root" cat-file -t "$anchor" 2>/dev/null) || return 2
  case "$kind" in
    commit|tree) ;;
    *) return 2 ;;
  esac

  build_excludes "$root"

  # Smoke-test the assembled pathspec. If git rejects it (malformed user
  # pattern, corrupted index, missing object), return 2; check maps that
  # to drift, so hooks block. Returning 1 here would map to check exit 2
  # which hooks fail-open on, re-opening the bypass.
  git -C "$root" status --porcelain -- "${EXCLUDES_LIST[@]}" >/dev/null 2>&1 || return 2

  # mktemp leaves an empty file, which git rejects as a corrupt index, so it
  # is removed first; build_scratch_index recreates it. The build runs in a
  # subshell to contain its `cd`, and its failure is coupled to return 2
  # (drift → block): a `git diff` against a *missing* GIT_INDEX_FILE silently
  # reports an empty index and exits 0, so a partial scratch would drop the
  # entire worktree segment from the hash and yield a stale-looking-but-
  # passing hash. A build failure must never read as a clean hash.
  scratch=$(mktemp) || return 1
  /bin/rm -f "$scratch"
  if ! ( build_scratch_index "$root" "$scratch" ); then
    /bin/rm -f "$scratch"
    return 2
  fi

  h=$(cd "$root" && {
        paths=$({
                  git diff --cached --name-only "$anchor" -- "${EXCLUDES_LIST[@]}"
                  GIT_INDEX_FILE="$scratch" git diff --name-only -- "${EXCLUDES_LIST[@]}"
                  # Force-include the config file: user `ignore` patterns
                  # must not hide config edits from the hash.
                  git diff --cached --name-only "$anchor" -- "$CONFIG_PATH"
                  GIT_INDEX_FILE="$scratch" git diff --name-only -- "$CONFIG_PATH"
                } | LC_ALL=C sort -u)
        if [ -n "$paths" ]; then
          while IFS= read -r p; do
            git diff --cached --binary --no-prefix "$anchor" -- "$p"
            GIT_INDEX_FILE="$scratch" git diff --binary --no-prefix -- "$p"
          done <<< "$paths"
        fi
      } 2>/dev/null | $sha 2>/dev/null | cut -d' ' -f1)
  for s in "${PIPESTATUS[@]}"; do
    [ "$s" -eq 0 ] || rc=1
  done
  /bin/rm -f "$scratch"
  [ $rc -eq 0 ] || return 1
  [ -n "$h" ] || return 1
  echo "sha256:$h"
}

# Mirrors 0.5.1's clean-tree fast-path so post-commit clean states pass
# regardless of the stored sentinel.
is_clean_tree() {
  local root="$1" status config_status
  build_excludes "$root"
  # Force not-clean when the config exists AND is gitignored: `git status`
  # can't see edits to ignored files, so the fast-path would short-circuit
  # past a real bypass. Tracked configs and untracked-not-gitignored
  # configs go through the status check normally, preserving the 0.6.0
  # multi-commit-doesn't-drift property after they're committed.
  if [ -f "$root/$CONFIG_PATH" ] \
     && (cd "$root" && git check-ignore -q "$CONFIG_PATH" 2>/dev/null); then
    return 1
  fi
  if ! status=$(cd "$root" && git status --porcelain --untracked-files=all -- \
                "${EXCLUDES_LIST[@]}" 2>/dev/null); then
    return 1
  fi
  # Independent visibility check for the config path. User `ignore`
  # patterns like `**` or `.claude/**` would otherwise hide config edits
  # from the main status call; we re-check the config path without
  # applying user excludes so those patterns can't fast-path past their
  # own edit.
  if ! config_status=$(cd "$root" && git status --porcelain --untracked-files=all -- \
                       "$CONFIG_PATH" 2>/dev/null); then
    return 1
  fi
  [ -z "$status" ] && [ -z "$config_status" ]
}

# Returns 0 with empty output when the file does not exist; nonzero with a
# stderr warning on malformed content.
read_sentinel() {
  local sentinel="$1" anchor_line hash_line
  [ -f "$sentinel" ] || return 0
  anchor_line=$(sed -n '1p' "$sentinel" 2>/dev/null | tr -d '[:space:]')
  hash_line=$(sed -n '2p' "$sentinel" 2>/dev/null | tr -d '[:space:]')
  if [[ "$anchor_line" =~ ^anchor:[a-f0-9]{40}$ ]] && \
     [[ "$hash_line"   =~ ^sha256:[a-f0-9]{64}$ ]]; then
    printf '%s\n%s\n' "$anchor_line" "$hash_line"
    return 0
  fi
  echo "review-sentinel: malformed sentinel at $sentinel; expected 'anchor:<40-hex>' + 'sha256:<64-hex>' (treating as drift)" >&2
  return 1
}

write_sentinel() {
  local sentinel="$1" content="$2" tmp err
  if ! err=$(mkdir -p "$(dirname "$sentinel")" 2>&1); then
    echo "review-sentinel: $err" >&2
    return 1
  fi
  tmp="${sentinel}.tmp.$$"
  # `command > file` redirects stdout to the file before any capture sees
  # it, so capturing stderr-as-stdout via $(... 2>&1) is impossible here.
  # Check the exit code directly; printf failures (full disk, EROFS) are
  # rare enough that the bare path in the error message suffices.
  if ! printf '%s\n' "$content" > "$tmp" 2>/dev/null; then
    echo "review-sentinel: write to $tmp failed" >&2
    /bin/rm -f "$tmp" 2>/dev/null
    return 1
  fi
  if ! err=$(mv "$tmp" "$sentinel" 2>&1); then
    echo "review-sentinel: rename $tmp -> $sentinel failed: $err" >&2
    /bin/rm -f "$tmp" 2>/dev/null
    return 1
  fi
  return 0
}

# Parse args and dispatch. Kept behind the BASH_SOURCE guard below so the file
# can be sourced (e.g. by bats) to unit-test individual functions without
# running a subcommand.
main() {
  ROOT_OVERRIDE=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --root)
        [ $# -ge 2 ] || usage
        ROOT_OVERRIDE="$2"
        shift 2
        ;;
      -h|--help|help)
        usage
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "review-sentinel: unknown option: $1" >&2
        usage
        ;;
      *)
        break
        ;;
    esac
  done

  [ $# -ge 1 ] || usage
  CMD="$1"
  shift

  case "$CMD" in
  seed|mark)
    PROJECT_ROOT=$(resolve_project_root)
    if [ -z "$PROJECT_ROOT" ]; then
      echo "review-sentinel: not in a git repo" >&2
      exit 1
    fi
    ANCHOR=$(current_anchor "$PROJECT_ROOT")
    HASH=$(compute_hash_from_anchor "$PROJECT_ROOT" "$ANCHOR")
    RC=$?
    if [ $RC -ne 0 ]; then
      echo "review-sentinel: cannot compute hash from anchor $ANCHOR" >&2
      exit 2
    fi
    write_sentinel "$PROJECT_ROOT/.claude/.review-mark" "anchor:$ANCHOR
$HASH" || {
      echo "review-sentinel: cannot write sentinel" >&2
      exit 2
    }
    exit 0
    ;;

  check)
    PROJECT_ROOT=$(resolve_project_root)
    [ -n "$PROJECT_ROOT" ] || exit 2
    is_clean_tree "$PROJECT_ROOT" && exit 0
    STORED=$(read_sentinel "$PROJECT_ROOT/.claude/.review-mark") || exit 1
    [ -n "$STORED" ] || exit 1
    STORED_ANCHOR=$(echo "$STORED" | sed -n '1p' | sed 's/^anchor://')
    STORED_HASH=$(echo "$STORED" | sed -n '2p')
    CURRENT_HASH=$(compute_hash_from_anchor "$PROJECT_ROOT" "$STORED_ANCHOR")
    RC=$?
    [ $RC -eq 1 ] && exit 2
    [ $RC -eq 2 ] && exit 1  # anchor unreachable: treat as drift
    [ "$CURRENT_HASH" = "$STORED_HASH" ] && exit 0
    exit 1
    ;;

  match)
    PROJECT_ROOT=$(resolve_project_root)
    [ -n "$PROJECT_ROOT" ] || exit 2
    STORED=$(read_sentinel "$PROJECT_ROOT/.claude/.review-mark") || exit 1
    [ -n "$STORED" ] || exit 1
    STORED_ANCHOR=$(echo "$STORED" | sed -n '1p' | sed 's/^anchor://')
    STORED_HASH=$(echo "$STORED" | sed -n '2p')
    CURRENT_HASH=$(compute_hash_from_anchor "$PROJECT_ROOT" "$STORED_ANCHOR")
    RC=$?
    [ $RC -eq 1 ] && exit 2  # real error (no sha tool, no work tree, pipeline failed)
    [ $RC -eq 2 ] && exit 1  # anchor unreachable: cannot match
    [ "$CURRENT_HASH" = "$STORED_HASH" ] && exit 0
    exit 1
    ;;

  current-hash)
    PROJECT_ROOT=$(resolve_project_root)
    if [ -z "$PROJECT_ROOT" ]; then
      echo "review-sentinel: not in a git repo" >&2
      exit 1
    fi
    ANCHOR=$(current_anchor "$PROJECT_ROOT")
    HASH=$(compute_hash_from_anchor "$PROJECT_ROOT" "$ANCHOR") || exit 2
    printf 'anchor:%s\n%s\n' "$ANCHOR" "$HASH"
    exit 0
    ;;

  paths)
    echo ".claude/.review-mark"
    echo ".claude/.no-review-gate"
    exit 0
    ;;

  *)
    echo "review-sentinel: unknown subcommand: $CMD" >&2
    usage
    ;;
  esac
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  main "$@"
fi
