#!/usr/bin/env bash
# Wrapper around bats that terminates the runner once all results have been
# emitted. Works around a post-suite cleanup hang on macOS where bats holds
# file descriptors open after the final `ok`/`not ok` line.
#
# Always invoke bats through this script, never directly — direct invocations
# leave orphaned bats processes that linger until the OS reaps them.
#
# Usage:
#   bin/run-bats                                # auto-discover every .bats in the repo
#   bin/run-bats path/to/suite.bats             # run one file
#   bin/run-bats dir/ another/file.bats         # run any combination of files/dirs
#   bin/run-bats -f "test name" path/to.bats    # pass through any bats arg

set -uo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

ARGS=("$@")
if [ ${#ARGS[@]} -eq 0 ]; then
  # `mapfile` is bash 4+ only; macOS ships bash 3.2 by default, so use a
  # portable read loop.
  while IFS= read -r bats_file; do
    ARGS+=("$bats_file")
  done < <(find "$REPO_ROOT" -type f -name '*.bats' \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    | sort)
  if [ ${#ARGS[@]} -eq 0 ]; then
    echo "bin/run-bats: no .bats files found under $REPO_ROOT" >&2
    exit 2
  fi
fi

OUT=$(mktemp)
trap '/bin/rm -f "$OUT"' EXIT

# bats spawns a formatter child (bats-format-cat). Killing the parent doesn't
# signal that child, so it gets reparented to launchd and lingers as an
# orphan. We need to walk the process tree.
kill_tree() {
  local parent="$1" child
  for child in $(pgrep -P "$parent" 2>/dev/null); do
    kill_tree "$child"
  done
  kill -KILL "$parent" 2>/dev/null || true
}

bats --tap "${ARGS[@]}" > "$OUT" 2>&1 &
BATS_PID=$!

EXPECTED=""
RESULT_COUNT=0
DEADLINE=$(($(date +%s) + 120))
EXIT_CODE=0

while [ "$(date +%s)" -lt $DEADLINE ]; do
  if ! kill -0 $BATS_PID 2>/dev/null; then
    wait $BATS_PID
    EXIT_CODE=$?
    break
  fi

  if [ -z "$EXPECTED" ]; then
    PLAN=$(grep -m1 -E '^1\.\.[0-9]+' "$OUT" 2>/dev/null || true)
    if [ -n "$PLAN" ]; then
      EXPECTED="${PLAN#1..}"
    fi
  fi

  if [ -n "$EXPECTED" ]; then
    RESULT_COUNT=$(grep -cE '^(ok|not ok) ' "$OUT" 2>/dev/null || true)
    [ -z "$RESULT_COUNT" ] && RESULT_COUNT=0
    if [ "$RESULT_COUNT" -ge "$EXPECTED" ]; then
      sleep 0.5
      if kill -0 $BATS_PID 2>/dev/null; then
        # Try graceful shutdown first; fall back to hard kill of the whole tree.
        kill -TERM $BATS_PID 2>/dev/null
        sleep 0.5
        kill_tree "$BATS_PID"
      fi
      wait $BATS_PID 2>/dev/null
      break
    fi
  fi

  sleep 0.2
done

cat "$OUT"

if [ -z "$EXPECTED" ]; then
  echo "bin/run-bats: no plan line emitted by bats" >&2
  exit 2
fi

FAILED=$(grep -cE '^not ok ' "$OUT" 2>/dev/null || true)
[ -z "$FAILED" ] && FAILED=0
if [ "$FAILED" -gt 0 ]; then
  exit 1
fi
if [ "$RESULT_COUNT" -lt "$EXPECTED" ]; then
  echo "bin/run-bats: only $RESULT_COUNT/$EXPECTED tests reported" >&2
  exit 2
fi
exit 0
